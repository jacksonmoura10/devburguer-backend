{
"env": {
"es2021": true,
"node": true
},
"extends": ["airbnb-base", "prettier"],
"plugins": ["prettier"],
"overrides": [],
"parserOptions": {
  "ecmaVersion": "latest",
  "sourceType": "module"
},
"rules": {
  "prettier/prettier": "error",
  "no-console": "off",
  "import/extensions": [
    "error",
    "ignorePackages",
  {
    "js": "never"
  }
],
  "import/no-unresolved": "off",
  "import/prefer-default-export": "off"
}
}
